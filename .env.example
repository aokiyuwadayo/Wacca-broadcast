# Anthropic API キー（https://console.anthropic.com/ で発行）
ANTHROPIC_API_KEY=

# 使うモデル（未設定なら Sonnet 4.6 = 安い×文章構成が上手いスイートスポット）
# コストを極限まで下げたい大規模時は Haiku に: claude-haiku-4-5-20251001
# 最高品質が欲しいときは Opus に: claude-opus-4-8
ANTHROPIC_MODEL=claude-sonnet-4-6

# 簡易パスワード保護（Basic認証）。設定すると合言葉を知る人だけ使える。
# 公開デプロイ（Vercel等）では必ず設定すること（中央APIキーの課金悪用を防ぐ）。
# ローカル開発では未設定でOK（その場合は保護なし）。
# SITE_PASSWORD=

# Supabase（Phase B〜: 保存・履歴・前回複製）
# https://supabase.com/dashboard/project/<id>/settings/api から取得
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role キー（サーバーサイドのみ。クライアントには絶対出さない）
SUPABASE_SERVICE_ROLE_KEY=

# ログイン必須化（Issue #8 認証の段階導入）。"1" で Supabase ログインを要求し、未ログインは /login へ。
# 未設定/それ以外なら認証ゲートはオフ＝現状どおり。Supabase 側で Email Auth を有効化し、
# 許可メールを絞ってから ON にすること。詳細は docs/phase-e-auth-plan.md。
# REQUIRE_AUTH=
